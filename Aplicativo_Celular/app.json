{
  "expo": {
    "name": "HidroAlerta",
    "slug": "HidroAlerta",
    "version": "1.0.0",
    "description": "Monitoramento inteligente da qualidade e disponibilidade da água.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hidroalerta",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#061A2F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.mdba.HidroAlerta"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#061A2F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#061A2F",
            "image": "./assets/images/splash-icon.png"
          },
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 180,
            "backgroundColor": "#061A2F"
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 180,
            "backgroundColor": "#061A2F"
          }
        }
      ],
      "expo-sharing",
      [
        "expo-audio",
        {
          "microphonePermission": "Permita que o HidroAlerta acesse o microfone para enviar mensagens de voz.",
          "enableBackgroundRecording": false
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "58da0ed6-0667-47e6-b45a-309ffda29b68"
      }
    }
  }
}
